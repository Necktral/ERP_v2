# Variables para Docker Compose (dev)
# Copia este archivo a .env y ajusta valores según tu entorno.
# Importante: NO commitees .env (está en .gitignore).

DJANGO_DEBUG=1
DJANGO_SECRET_KEY=change-me-please
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# Frontend (Quasar) corre en http://localhost:3000
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DJANGO_CSP_CONNECT_SRC=http://localhost:8000,http://127.0.0.1:8000,https://api.necktral.com
TOTP_ISSUER=Necktral
TOTP_CHALLENGE_TTL=300
TOTP_VALID_WINDOW=1

# Auth transport (cookie por defecto; 'header' habilita JWT por Authorization)
AUTH_TOKEN_TRANSPORT=cookie
# No permitir override por header/query en produccion.
AUTH_ALLOW_TRANSPORT_OVERRIDE=0
AUTH_COOKIE_ACCESS_NAME=nt_access
AUTH_COOKIE_REFRESH_NAME=nt_refresh
AUTH_COOKIE_CSRF_NAME=nt_csrf
AUTH_COOKIE_SECURE=0
AUTH_COOKIE_SAMESITE=Lax
# Recomendado: 1 en LAN/PROD con HTTPS real para sesión móvil autenticada.
AUTH_COOKIE_REQUIRE_HTTPS=0
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/

# Postgres (los valores se usan para inicializar el contenedor db)
DB_ENGINE=django.db.backends.postgresql

# Variables estándar de Postgres (recomendado)
POSTGRES_DB=loggin_db
POSTGRES_USER=loggin_user
POSTGRES_PASSWORD=loggin_pass_change_me

# Host/puerto para desarrollo local (en Docker Compose se sobreescriben a db:5432)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Legacy (opcional): si tu entorno usa DB_* el backend también lo acepta.
# DB_NAME=loggin_db
# DB_USER=loggin_user
# DB_PASSWORD=loggin_pass_change_me
# DB_HOST=127.0.0.1
# DB_PORT=5432

# Auditoría (HMAC). En entornos reales debe ser largo y aleatorio.
AUDIT_HMAC_KEY=change-me-strong-random
AUDIT_HMAC_KEYS=rot1:change-me-strong-random-rot1,legacy:change-me-strong-random

# Observabilidad (Sentry)
SENTRY_DSN=
SENTRY_ENVIRONMENT=dev
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_RELEASE=

# Throttling (defaults seguros; override en QA si es necesario)
DRF_THROTTLE_ANON=60/min
DRF_THROTTLE_USER=600/min
DRF_THROTTLE_AUTH_LOGIN=20/min
DRF_THROTTLE_AUTH_REFRESH=60/min
DRF_THROTTLE_AUTH_LOGOUT=60/min
DRF_THROTTLE_ME_READ=60/min
DRF_THROTTLE_ME_ACL_READ=30/min

# Fiscal Adapter B (Fase 9 provider real)
FISCAL_ADAPTER_MODE=NOOP
FISCAL_ADAPTER_B_PROVIDER=EMULATED
FISCAL_ADAPTER_B_HTTP_BASE_URL=
FISCAL_ADAPTER_B_HTTP_API_KEY=
FISCAL_ADAPTER_B_HTTP_TIMEOUT_SECONDS=15
FISCAL_ADAPTER_B_HTTP_VERIFY_TLS=1

# Sync enrollment PWA (URL pública de frontend para QR de dispositivo)
SYNC_ENROLL_WEB_BASE_URL=http://localhost:3000
