# Variables para Docker Compose (dev)
# Copia este archivo a .env y ajusta valores según tu entorno.
# Importante: NO commitees .env (está en .gitignore).

DJANGO_DEBUG=1
DJANGO_SECRET_KEY=change-me-please
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend (Quasar) corre en http://localhost:3000
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Postgres (los valores se usan para inicializar el contenedor db)
DB_ENGINE=django.db.backends.postgresql

# Variables estándar de Postgres (recomendado)
POSTGRES_DB=loggin_db
POSTGRES_USER=loggin_user
POSTGRES_PASSWORD=loggin_pass_change_me

# Host/puerto para desarrollo local (en Docker Compose se sobreescriben a db:5432)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Legacy (opcional): si tu entorno usa DB_* el backend también lo acepta.
# DB_NAME=loggin_db
# DB_USER=loggin_user
# DB_PASSWORD=loggin_pass_change_me
# DB_HOST=127.0.0.1
# DB_PORT=5432

# Auditoría (HMAC). En entornos reales debe ser largo y aleatorio.
AUDIT_HMAC_KEY=change-me-strong-random
