# F11 Intercompany avanzado - cron ejemplo
# Timezone operativa
CRON_TZ=America/Managua

# Ajustar paths/usuario según entorno
ROOT=/home/necktral/ERP_CRM
OUT=$ROOT/docs/operacion/evidencia/phase11_go_live_live

# ciclo continuo cada 5 minutos
*/5 * * * 1-5 cd $ROOT && OUT_DIR=$OUT COMPANY_ID=5 BRANCH_ID=6 $ROOT/qa/run_phase11_go_live.sh cycle >> $OUT/cron_cycle.log 2>&1

# gate diario
10 18 * * 1-5 cd $ROOT && OUT_DIR=$OUT COMPANY_ID=5 BRANCH_ID=6 $ROOT/qa/run_phase11_go_live.sh gate >> $OUT/cron_gate.log 2>&1

# resumen diario (hash + matriz)
15 18 * * 1-5 cd $ROOT && OUT_DIR=$OUT COMPANY_ID=5 BRANCH_ID=6 $ROOT/qa/run_phase11_go_live.sh summary >> $OUT/cron_summary.log 2>&1
