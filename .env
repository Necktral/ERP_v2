# ===== Django =====
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Si Quasar corre en 9000, agrega ese origen.
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:9000,http://127.0.0.1:9000,http://localhost:3000,http://127.0.0.1:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:9000,http://127.0.0.1:9000,http://localhost:3000,http://127.0.0.1:3000

# Auditoría (no lo dejes default en entornos reales)
AUDIT_HMAC_KEY=CHANGE_ME_AUDIT_KEY

# ===== Postgres =====
DB_ENGINE=django.db.backends.postgresql
DB_NAME=erpcrm_db
DB_USER=erpcrm_user
DB_PASSWORD=erpcrm_strong_password_change_me
# DB_HOST se fuerza a "db" en compose para el contenedor.
DB_PORT=5432
