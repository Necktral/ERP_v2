# --- Django PROD ---
DJANGO_DEBUG=0
DJANGO_SECRET_KEY=pon-aqui-una-clave-larga-aleatoria
DJANGO_ALLOWED_HOSTS=tu-dominio.com,tu-ip-lan

# Frontend en mismo origen (web) => https://tu-dominio
DJANGO_CORS_ALLOWED_ORIGINS=https://tu-dominio.com,https://tu-ip-lan
DJANGO_CSRF_TRUSTED_ORIGINS=https://tu-dominio.com,https://tu-ip-lan
AUTH_TOKEN_TRANSPORT=cookie
AUTH_ALLOW_TRANSPORT_OVERRIDE=0
AUTH_COOKIE_REQUIRE_HTTPS=1

# Auditoría contractual (HMAC fuerte)
AUDIT_HMAC_KEY=pon-aqui-una-clave-muy-larga-aleatoria
AUDIT_HMAC_KEYS=rot1:pon-aqui-una-clave-rot1,legacy:pon-aqui-una-clave-legacy

# Observabilidad (Sentry)
SENTRY_DSN=
SENTRY_ENVIRONMENT=prod
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_RELEASE=

# --- Postgres ---
DB_ENGINE=django.db.backends.postgresql
POSTGRES_DB=erpcrm_db
POSTGRES_USER=erpcrm_user
POSTGRES_PASSWORD=pon-un-password-fuerte
POSTGRES_HOST=db
POSTGRES_PORT=5432
