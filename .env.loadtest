# Perfil recomendado para corridas de carga (150k+) sin tocar .env base.
# Copia este archivo a .env.loadtest y reemplaza los valores CHANGE_ME.
#
# Uso:
#   cp .env.loadtest.example .env.loadtest
#   ./simulacion/run_advanced_integral.sh
# o
#   LOADTEST_ENV_FILE=.env.loadtest ./simulacion/run_advanced_integral.sh
#
# Variables obligatorias para arrancar:
#   AUTH_SIM_ADMIN_PASSWORD
#   AUTH_SIM_USER_PASSWORD
#   AUTH_SIM_ADMIN_TOTP_SECRET
#   COMPANY_ID
#   BRANCH_ID
#   USERNAME
#   PASSWORD

# --- Compatibilidad Docker/host para k6 -> backend ---
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver,backend,erpcrm_backend
BASE_URL=http://backend:8000/api
# La suite operacional requiere tokens en body (modo header).
AUTH_TOKEN_TRANSPORT=header
# Permite override por request para escenarios mixtos cookie/header.
AUTH_ALLOW_TRANSPORT_OVERRIDE=1

# --- Backend worker profile para carga ---
USE_GUNICORN=1
GUNICORN_WORKERS=16

# --- Throttling alto para pruebas de volumen (no usar en entorno normal) ---
DRF_THROTTLE_ANON=12000/min
DRF_THROTTLE_USER=12000/min
DRF_THROTTLE_AUTH_LOGIN=6000/min
DRF_THROTTLE_AUTH_REFRESH=6000/min
DRF_THROTTLE_AUTH_LOGOUT=6000/min
DRF_THROTTLE_AUTH_SENSITIVE=6000/min
DRF_THROTTLE_ME_READ=12000/min
DRF_THROTTLE_ME_ACL_READ=12000/min

# --- Auth load ---
AUTH_SIM_ADMIN_USERNAME=k6_admin
AUTH_SIM_ADMIN_PASSWORD=Aa!9_Sim_Seed
AUTH_SIM_ADMIN_TOTP_SECRET=JBSWY3DPEHPK3PXP
AUTH_SIM_USER_USERNAME=k6_user
AUTH_SIM_USER_PASSWORD=Aa!9_Sim_Seed
CSRF_COOKIE_NAME=nt_csrf

# --- Operacional load ---
COMPANY_ID=2
BRANCH_ID=3
USERNAME=k6_operational
PASSWORD=Aa!9_Sim_Seed
WAREHOUSE_ID=
ITEM_ID=

# --- Corrida ---
TARGET_HTTP_REQS=150000
TOTAL_DURATION=15m
AUTH_VUS=120
AUTH_ADMIN_2FA_VUS=6
AUTH_ADMIN_2FA_SLEEP=1
OPER_BILLING_VUS=80
OPER_INVENTORY_VUS=80
OPER_POSTING_VUS=24

# Gates post-carga
RUN_QA_GATES=1
RUN_SECURITY_SCAN=1
DJANGO_JWT_SIGNING_KEY=loadtest-jwt-signing-key-2026-erpcrm-min-32bytes-abcdef
